{
  "AppPolicy": {
    "ServiceMode": "DirectoryReadOnly",
    "LogPath": "C:\\ProgramData\\ManageAdTool\\logs\\audit.jsonl",
    "MaxSearchResults": 200,

    "EditorAuthMode": "DomainAdmins",
    "AdminGroupDn": "CN=Domain Admins,CN=Users,DC=example,DC=local",
    "AllowNestedAdminGroupMembership": false,
    "EditSessionMinutes": 15,

    "AllowedTargetOuDns": [
      "OU=Users,DC=example,DC=local"
    ],
    "ExcludedSamAccountNames": [
      "administrator",
      "krbtgt"
    ],
    "EditableAttributes": ["mail", "displayName", "sn", "givenName"],

    "AllowedComputerOuDns": [
      "OU=Computers,DC=example,DC=local"
    ],
    "ExcludedComputerNames": ["DC-01", "DC-02"],
    "EditableComputerAttributes": ["description"],

    "EditableGroupOuDns": [
      "OU=Groups,DC=example,DC=local"
    ],
    "_EditableGroupOuDns_note": "EditableGroupOuDns を明示設定することを必須とします。空の場合グループメンバー更新は実行不可（セーフガード）。編集可能なグループを特定のOUに限定することで意図しない変更を防止します。",
    "ProtectedGroupNames": [
      "Domain Admins",
      "Enterprise Admins",
      "Schema Admins",
      "Administrators"
    ],
    "ProtectedGroupDns": [
      "CN=Domain Admins,CN=Users,DC=example,DC=local",
      "CN=Enterprise Admins,CN=Users,DC=example,DC=local"
    ],
    "_ProtectedGroups_note": "ProtectedGroupNames / ProtectedGroupDns に登録されたグループはメンバー追加・削除不可。特権グループは必ず登録してください。"
  }
}
