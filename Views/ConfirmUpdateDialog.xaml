<Window x:Class="ManageAdTool.Views.ConfirmUpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AD更新実行前確認" Height="560" Width="660"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"
                   Text="この内容でADを更新します。内容を十分に確認してから実行してください。"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="対象 SamAccountName:" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SamText" Grid.Column="1" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Text="対象 DisplayName:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock x:Name="DisplayNameText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2" Text="対象 DistinguishedName:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="DnText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="3" Text="実行端末:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock x:Name="MachineText" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="4" Text="アプリ起動ユーザー:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock x:Name="ExecutorText" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="5" Text="編集セッションユーザー:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock x:Name="EditorText" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0"/>
                </Grid>

                <Separator Margin="0,4,0,8"/>

                <TextBlock FontWeight="Bold" Margin="0,0,0,6"
                           Text="変更内容（更新対象: mail / department / title のみ、空文字更新は禁止）:"/>

                <Grid Margin="4,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Foreground="Gray" FontSize="11" Text="属性"/>
                    <TextBlock Grid.Column="1" Foreground="Gray" FontSize="11" Text="変更前（現在値）"/>
                    <TextBlock Grid.Column="3" Foreground="Gray" FontSize="11" Text="変更後（新しい値）"/>
                </Grid>

                <ItemsControl x:Name="ChangesList" Margin="4,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Field}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding LdapAttribute}" Foreground="Gray" FontSize="10"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding Before}" IsReadOnly="True"
                                         Background="#FFF0F0" BorderBrush="#FFCCCC" Padding="4,2" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="→" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="3" Text="{Binding After}" IsReadOnly="True"
                                         Background="#F0FFF0" BorderBrush="#AADDAA" Padding="4,2" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#FFFFF0" BorderBrush="Goldenrod" BorderThickness="1" Padding="8" Margin="0,0,0,12">
            <TextBlock TextWrapping="Wrap" Foreground="DarkGoldenrod">
                <Run FontWeight="Bold" Text="【注意】"/>
                <Run Text="この操作は実 AD に書き込みます。更新後は元に戻すには手動操作が必要です。"/>
                <LineBreak/>
                <Run Text="グループ操作・OU移動・ユーザー無効化などは実行しません。更新内容は監査ログ（write-audit.jsonl）に記録されます。"/>
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="90" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
            <Button Content="この内容でADを更新する" Width="160" IsDefault="True" Click="OK_Click"
                    Background="#CC3333" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
