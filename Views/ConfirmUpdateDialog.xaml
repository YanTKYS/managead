<Window x:Class="ManageAdTool.Views.ConfirmUpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AD更新実行前確認" Height="440" Width="600"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"
                   Text="以下の内容でADを更新します。内容を確認してください。"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="対象 SamAccountName:" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SamText" Grid.Column="1" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Text="対象 DistinguishedName:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="DnText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="2" Text="編集セッション ユーザー:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock x:Name="EditorText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="3" Text="アプリ実行ユーザー:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock x:Name="ExecutorText" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0"/>
                </Grid>

                <Separator Margin="0,4,0,8"/>

                <TextBlock FontWeight="Bold" Margin="0,0,0,4" Text="変更内容:"/>
                <ItemsControl x:Name="ChangesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Field}" FontWeight="Bold"/>
                                <TextBox Grid.Column="1" Text="{Binding Before}" IsReadOnly="True" Background="#FFF0F0" BorderThickness="0"/>
                                <TextBlock Grid.Column="2" Text="→" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="3" Text="{Binding After}" IsReadOnly="True" Background="#F0FFF0" BorderThickness="0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#FFFFF0" BorderBrush="Goldenrod" BorderThickness="1" Padding="8" Margin="0,0,0,12">
            <TextBlock TextWrapping="Wrap" Foreground="DarkGoldenrod"
                       Text="【注意】この操作は実 AD に書き込みます。対象属性: mail / department / title のみ。グループ操作・OU移動・無効化などは実行しません。更新後は監査ログ（write-audit.jsonl）に記録されます。"/>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="限定更新実行" Width="110" IsDefault="True" Click="OK_Click"
                    Background="#CC3333" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
