<Window x:Class="ManageAdTool.Views.ReAuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="再認証（AD更新実行）" Height="210" Width="440"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,12" TextWrapping="Wrap"
                   Text="AD更新を実行するには再認証が必要です。Domain Admins アカウントで認証してください。"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="ユーザー (domain\user)" VerticalAlignment="Center"/>
            <TextBox x:Name="UserBox" Grid.Column="1"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="パスワード" VerticalAlignment="Center"/>
            <PasswordBox x:Name="PasswordBox" Grid.Column="1"/>
        </Grid>

        <TextBlock x:Name="ErrorText" Grid.Row="3" Foreground="DarkRed" Margin="0,0,0,8"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="認証して続行" Width="100" IsDefault="True" Click="OK_Click"/>
        </StackPanel>
    </Grid>
</Window>
