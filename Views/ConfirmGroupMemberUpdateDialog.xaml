<Window x:Class="ManageAdTool.Views.ConfirmGroupMemberUpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="グループメンバー更新実行前確認" Height="580" Width="700"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"
                   Text="この内容でグループメンバーを更新します。内容を十分に確認してから実行してください。"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="対象種別:" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Group（グループ）" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Text="対象 グループ名:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock x:Name="GroupNameText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2" Text="対象 DistinguishedName:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="DnText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="3" Text="実行端末 / 起動ユーザー:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock x:Name="MachineExecutorText" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="4" Text="編集セッションユーザー:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock x:Name="EditorText" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,0"/>
                </Grid>

                <Separator Margin="0,4,0,8"/>

                <TextBlock FontWeight="Bold" Margin="0,0,0,6"
                           Text="変更内容（追加・削除対象はユーザーのみ。コンピュータ・グループの追加は行いません）:"/>

                <TextBlock x:Name="AddHeaderText" FontWeight="Bold" Foreground="DarkGreen" Margin="0,4,0,2"/>
                <ItemsControl x:Name="AddList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F0FFF0" BorderBrush="#AADDAA" BorderThickness="1" Padding="6,3" Margin="0,2,0,0">
                                <TextBlock Text="{Binding}" Foreground="DarkGreen" FontWeight="Bold"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="RemoveHeaderText" FontWeight="Bold" Foreground="DarkRed" Margin="0,8,0,2"/>
                <ItemsControl x:Name="RemoveList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFF0F0" BorderBrush="#FFCCCC" BorderThickness="1" Padding="6,3" Margin="0,2,0,0">
                                <TextBlock Text="{Binding}" Foreground="DarkRed" FontWeight="Bold"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#FFFFF0" BorderBrush="Goldenrod" BorderThickness="1" Padding="8" Margin="0,0,0,12">
            <TextBlock TextWrapping="Wrap" Foreground="DarkGoldenrod">
                <Run FontWeight="Bold" Text="【注意】"/>
                <Run Text="この操作は実 AD に書き込みます。追加されたユーザーは対象グループのメンバーになります。"/>
                <LineBreak/>
                <Run Text="追加・削除対象はユーザーのみです。グループのグループ追加・コンピュータ追加・グループ削除・グループ作成・一括更新は実行しません。更新内容は監査ログ（write-audit.jsonl）に記録されます。"/>
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="90" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
            <Button Content="この内容でADを更新する" Width="180" IsDefault="True" Click="OK_Click"
                    Background="#CC3333" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
