<Window x:Class="ManageAdTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ManageAdTool MVP" Height="640" Width="980">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="170"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox x:Name="SearchBox" Width="240" Margin="0,0,8,0" />
            <Button Content="検索" Click="Search_Click" Width="100"/>
        </StackPanel>

        <DataGrid x:Name="SearchResultGrid" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="SearchResultGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="SamAccountName" Binding="{Binding SamAccountName}" Width="2*"/>
                <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="2*"/>
                <DataGridTextColumn Header="Mail" Binding="{Binding Mail}" Width="3*"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="2" Header="属性編集 (Mail / Department / Title)" Margin="0,8,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Text="Mail"/><TextBox x:Name="MailBox" Grid.Column="1"/>
                <TextBlock Text="Department" Grid.Row="1"/><TextBox x:Name="DepartmentBox" Grid.Row="1" Grid.Column="1"/>
                <TextBlock Text="Title" Grid.Row="2"/><TextBox x:Name="TitleBox" Grid.Row="2" Grid.Column="1"/>
            </Grid>
        </GroupBox>

        <DockPanel Grid.Row="3">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="差分確認" Width="100" Margin="0,0,8,0" Click="Preview_Click"/>
                <Button Content="更新実行" Width="100" Click="Execute_Click"/>
            </StackPanel>
            <TextBox x:Name="OutputBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
        </DockPanel>
    </Grid>
</Window>
