<Window x:Class="ManageAdTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ManageAdTool" Height="980" Width="1200"
        MinWidth="900" MinHeight="720"
        Background="{StaticResource AppBgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header band -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="ManageAdTool" Style="{StaticResource AppTitleStyle}"/>
                    <TextBlock Text="AD 参照・限定更新支援ツール" Style="{StaticResource AppSubTitleStyle}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="現在のモード: "
                                   Style="{StaticResource ModeLabelStyle}"/>
                        <TextBlock Text="{Binding ServiceModeText}"
                                   Style="{StaticResource ModeLabelStyle}" FontWeight="Bold"/>
                        <TextBlock Text="（" Style="{StaticResource ModeLabelStyle}"/>
                        <TextBlock Text="{Binding ServiceModeDescText}"
                                   Style="{StaticResource ModeLabelStyle}"/>
                        <TextBlock Text="）" Style="{StaticResource ModeLabelStyle}"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="ヘルプ" VerticalAlignment="Center"
                        Click="OpenHelp_Click" Style="{StaticResource HeaderButtonStyle}"/>
            </Grid>
        </Border>

        <!-- Row 1: Login / action bar -->
        <Border Grid.Row="1" Background="{StaticResource ActionBarBgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="14,8,14,8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Text="編集者ログイン（Domain Admins）"
                                   VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,14,0"/>
                        <TextBlock Text="ユーザー (domain\user)" VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelStyle}" Margin="0,0,4,0"/>
                        <TextBox x:Name="EditorUserBox" Width="184" Height="26" Margin="0,0,10,0"
                                 IsEnabled="{Binding CanLoginInput}"/>
                        <TextBlock Text="パスワード" VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelStyle}" Margin="0,0,4,0"/>
                        <PasswordBox x:Name="EditorPasswordBox" Width="144" Height="26"
                                     Margin="0,0,10,0" IsEnabled="{Binding CanLoginInput}"
                                     VerticalContentAlignment="Center" Padding="6,0"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                        <Button Content="ログイン" Width="76" Margin="0,0,6,0"
                                Click="Login_Click" IsEnabled="{Binding CanLoginInput}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Content="ログアウト" Width="84"
                                Click="Logout_Click" IsEnabled="{Binding IsEditSessionActive}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </WrapPanel>
                </Grid>
                <TextBlock Text="{Binding SessionStatusText}" FontSize="11"
                           Foreground="{Binding SessionStatusBrush}"
                           TextWrapping="Wrap" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Row 2: Main tab control -->
        <TabControl Grid.Row="2" Margin="8,8,8,0" FontSize="12">

            <!-- ==================== Tab: ユーザー詳細 ==================== -->
            <TabItem Header="ユーザー詳細">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="150" MinHeight="100"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="0"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <Border Grid.Row="0" Background="{StaticResource ActionBarBgBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="検索語" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                            <TextBox x:Name="SearchBox" Width="230" Height="26" Margin="0,0,10,0"/>
                            <CheckBox x:Name="IncludeDisabledUsersBox" Content="無効ユーザーも表示"
                                      VerticalAlignment="Center" Margin="0,0,12,0" FontSize="12"/>
                            <Button Content="検索" Width="80" Margin="0,0,8,0"
                                    Click="Search_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                            <Button Content="CSV出力" Width="90"
                                    Click="ExportSearchResults_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                        </WrapPanel>
                    </Border>

                    <!-- Search result DataGrid -->
                    <DataGrid x:Name="SearchResultGrid" Grid.Row="1"
                              AutoGenerateColumns="False" SelectionMode="Single"
                              IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionChanged="SearchResultGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SamAccountName" Binding="{Binding SamAccountName}" Width="2*"/>
                            <DataGridTextColumn Header="DisplayName"    Binding="{Binding DisplayName}"    Width="2*"/>
                            <DataGridTextColumn Header="Mail"           Binding="{Binding Mail}"           Width="3*"/>
                            <DataGridCheckBoxColumn Header="有効"       Binding="{Binding Enabled}"        Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Edit blocked reason -->
                    <TextBlock x:Name="EditBlockedReasonText" Grid.Row="2"
                               Text="{Binding EditBlockedReason}"
                               Style="{StaticResource ErrorTextStyle}"
                               Margin="0,6,0,4"/>

                    <!-- Attribute edit card -->
                    <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource CardHeaderBorderStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="属性編集（限定更新）"
                                               Style="{StaticResource SectionHeadingStyle}"/>
                                    <Border Style="{StaticResource BadgeWarningStyle}" Margin="10,0,0,0">
                                        <TextBlock Text="更新対象: mail / displayName / sn / givenName　ユーザー名は参照のみ　Domain Admins セッション必須"
                                                   FontSize="10" Foreground="{StaticResource WarningBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Grid Margin="10,8,10,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="メールアドレス (mail)"
                                           Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="EditMailBox" Grid.Column="1" Height="26"
                                         IsEnabled="{Binding EditControlsEnabled}"
                                         TextChanged="EditInput_TextChanged"/>
                                <TextBlock Text="表示名 (displayName)" Grid.Row="1"
                                           Style="{StaticResource FieldLabelStyle}" Margin="0,5,0,0"/>
                                <TextBox x:Name="EditDisplayNameBox" Grid.Row="1" Grid.Column="1"
                                         Height="26" Margin="0,5,0,0"
                                         IsEnabled="{Binding EditControlsEnabled}"
                                         TextChanged="EditInput_TextChanged"/>
                                <TextBlock Text="姓 (sn)" Grid.Row="2"
                                           Style="{StaticResource FieldLabelStyle}" Margin="0,5,0,0"/>
                                <TextBox x:Name="EditSurnameBox" Grid.Row="2" Grid.Column="1"
                                         Height="26" Margin="0,5,0,0"
                                         IsEnabled="{Binding EditControlsEnabled}"
                                         TextChanged="EditInput_TextChanged"/>
                                <TextBlock Text="名 (givenName)" Grid.Row="3"
                                           Style="{StaticResource FieldLabelStyle}" Margin="0,5,0,0"/>
                                <TextBox x:Name="EditGivenNameBox" Grid.Row="3" Grid.Column="1"
                                         Height="26" Margin="0,5,0,0"
                                         IsEnabled="{Binding EditControlsEnabled}"
                                         TextChanged="EditInput_TextChanged"/>
                                <TextBlock Text="ユーザー名 ※参照のみ（高リスク）" Grid.Row="4"
                                           Style="{StaticResource MutedTextStyle}" Margin="0,5,0,0"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="SamAccountNameReadBox" Grid.Row="4" Grid.Column="1"
                                         Height="26" Margin="0,5,0,0"
                                         IsReadOnly="True"
                                         ToolTip="ユーザー名（sAMAccountName）は参照のみです。"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- User detail + groups (scrollable, Row 4) -->
                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,0,4">

                            <!-- User detail -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource CardHeaderBorderStyle}">
                                        <TextBlock Text="ユーザー詳細（参照専用）"
                                                   Style="{StaticResource SectionHeadingStyle}"/>
                                    </Border>
                                    <TextBox x:Name="UserDetailBox" Height="120" Margin="8"
                                             IsReadOnly="True" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Group list -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                                <StackPanel>
                                    <Border Style="{StaticResource CardHeaderBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="所属グループ（参照専用・名前順）"
                                                       Style="{StaticResource SectionHeadingStyle}"/>
                                            <Button Content="コピー" Margin="12,0,0,0"
                                                    Click="CopyGroups_Click"
                                                    Style="{StaticResource GhostButtonStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBox x:Name="GroupListBox" Height="80" Margin="8"
                                             IsReadOnly="True" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Action buttons (Row 5 — 常時表示) -->
                    <StackPanel Grid.Row="5" Margin="0,6,0,4">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button x:Name="PreviewButton" Content="差分確認" Width="100"
                                    Margin="0,0,8,0" Click="Preview_Click"
                                    IsEnabled="{Binding EditControlsEnabled}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button x:Name="ExecuteButton" Content="限定更新実行" Width="130"
                                    Margin="0,0,8,0" Click="Execute_Click"
                                    IsEnabled="{Binding IsWriteButtonEnabled}"
                                    Style="{StaticResource DangerButtonStyle}"/>
                            <Button x:Name="CopyRevertMemoButton" Content="戻し用メモをコピー"
                                    Width="150" Click="CopyRevertMemo_Click" IsEnabled="False"
                                    Style="{StaticResource GhostButtonStyle}"
                                    ToolTip="更新成功後に変更前の値をクリップボードにコピーします"/>
                        </StackPanel>
                        <TextBlock Text="{Binding WriteButtonDisabledReason}"
                                   Style="{StaticResource ErrorTextStyle}" Margin="0,0,0,2"/>
                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                   Text="※ 更新対象: メールアドレス / 表示名 / 姓 / 名。ユーザー名は参照のみ。空文字更新は禁止。実行前に再認証と確認が必要です。"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ==================== Tab: グループ参照・メンバー編集 ==================== -->
            <TabItem Header="グループ参照・メンバー編集">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="110"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Group search bar -->
                    <Border Grid.Row="0" Background="{StaticResource ActionBarBgBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="グループ検索" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                            <TextBox x:Name="GroupSearchBox" Width="270" Height="26" Margin="0,0,10,0"/>
                            <Button Content="検索" Width="80"
                                    Click="GroupSearch_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </WrapPanel>
                    </Border>

                    <!-- Group search result -->
                    <DataGrid x:Name="GroupSearchResultGrid" Grid.Row="1"
                              AutoGenerateColumns="False" SelectionMode="Single"
                              IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionChanged="GroupSearchResultGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="グループ名"         Binding="{Binding Name}"              Width="2*"/>
                            <DataGridTextColumn Header="DistinguishedName" Binding="{Binding DistinguishedName}" Width="5*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Detail + edit split panel -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: member detail -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="100"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,6">
                                <TextBox x:Name="GroupDetailBox" IsReadOnly="True" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                         BorderThickness="0" Padding="6"/>
                            </Border>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="ユーザーメンバー（直接所属のみ）"
                                           Style="{StaticResource SectionHeadingStyle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="GroupMemberCountText" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Button Content="削除予定へ" Width="100" Margin="10,0,0,0"
                                        Click="GroupAddToRemoveStaging_Click"
                                        IsEnabled="{Binding GroupEditControlsEnabled}"
                                        Style="{StaticResource GhostButtonStyle}"
                                        ToolTip="選択中のユーザーを削除予定リストに追加します"/>
                            </StackPanel>
                            <DataGrid x:Name="GroupUserMemberGrid" Grid.Row="2"
                                      AutoGenerateColumns="False" SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="SamAccountName" Binding="{Binding SamAccountName}" Width="2*"/>
                                    <DataGridTextColumn Header="DisplayName"    Binding="{Binding DisplayName}"    Width="2*"/>
                                    <DataGridTextColumn Header="Mail"           Binding="{Binding Mail}"           Width="3*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBox x:Name="GroupOtherMembersBox" Grid.Row="3"
                                     IsReadOnly="True" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" Height="54"
                                     Margin="0,6,0,0" FontSize="11"
                                     ToolTip="コンピュータメンバー、ネストグループ、所属グループ（memberOf）"/>
                        </Grid>

                        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                      Background="{StaticResource BorderBrush}"/>

                        <!-- Right: edit panel -->
                        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="6,0,0,0">
                            <StackPanel>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Border Style="{StaticResource CardHeaderBorderStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="メンバー編集"
                                                           Style="{StaticResource SectionHeadingStyle}"/>
                                                <Border Style="{StaticResource BadgeWarningStyle}" Margin="8,0,0,0">
                                                    <TextBlock Text="ユーザーのみ・Domain Admins必須"
                                                               FontSize="10" Foreground="{StaticResource WarningBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                        <StackPanel Margin="8">
                                            <TextBlock Text="{Binding GroupEditBlockedReason}"
                                                       Style="{StaticResource ErrorTextStyle}" Margin="0,0,0,6"/>
                                            <TextBlock Text="追加するユーザーの SamAccountName:"
                                                       Style="{StaticResource MutedTextStyle}" Margin="0,0,0,3"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBox x:Name="GroupAddUserBox" Width="140" Height="26"
                                                         Margin="0,0,6,0"
                                                         IsEnabled="{Binding GroupEditControlsEnabled}"/>
                                                <Button Content="検索して追加予定へ" FontSize="11"
                                                        Padding="8,0" Height="26"
                                                        Click="GroupAddUserToStaging_Click"
                                                        IsEnabled="{Binding GroupEditControlsEnabled}"
                                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                <TextBlock Text="追加予定:" FontWeight="SemiBold" FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource SuccessBrush}"/>
                                                <Button Content="除去" FontSize="11" Height="22"
                                                        Margin="6,0,0,0" Padding="8,0"
                                                        Click="GroupRemoveFromAddStaging_Click"
                                                        Style="{StaticResource GhostButtonStyle}"/>
                                            </StackPanel>
                                            <ListBox x:Name="GroupAddStagingList" Height="64"
                                                     FontSize="11" Margin="0,0,0,8"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                <TextBlock Text="削除予定:" FontWeight="SemiBold" FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource DangerBrush}"/>
                                                <Button Content="除去" FontSize="11" Height="22"
                                                        Margin="6,0,0,0" Padding="8,0"
                                                        Click="GroupRemoveFromRemoveStaging_Click"
                                                        Style="{StaticResource GhostButtonStyle}"/>
                                            </StackPanel>
                                            <ListBox x:Name="GroupRemoveStagingList" Height="64"
                                                     FontSize="11" Margin="0,0,0,10"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Button x:Name="GroupPreviewButton" Content="差分確認"
                                                        Width="90" Margin="0,0,8,0"
                                                        Click="GroupPreview_Click"
                                                        IsEnabled="{Binding GroupEditControlsEnabled}"
                                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button x:Name="GroupExecuteButton" Content="限定更新実行"
                                                        Width="120"
                                                        Click="GroupExecute_Click"
                                                        IsEnabled="{Binding IsGroupWriteButtonEnabled}"
                                                        Style="{StaticResource DangerButtonStyle}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding GroupWriteButtonDisabledReason}"
                                                       Style="{StaticResource ErrorTextStyle}" Margin="0,0,0,2"/>
                                            <TextBlock Style="{StaticResource MutedTextStyle}"
                                                       Text="※ ユーザーのみ追加・削除可能。コンピュータ・グループの追加は不可。グループ作成・削除・リネームは実行しません。"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ==================== Tab: コンピュータ参照 ==================== -->
            <TabItem Header="コンピュータ参照">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="160"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Computer search bar -->
                    <Border Grid.Row="0" Background="{StaticResource ActionBarBgBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="検索語" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                            <TextBox x:Name="ComputerSearchBox" Width="190" Height="26" Margin="0,0,10,0"/>
                            <TextBlock Text="OS" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,4,0"/>
                            <TextBox x:Name="ComputerOsFilterBox" Width="140" Height="26" Margin="0,0,10,0"/>
                            <TextBlock Text="description" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,4,0"/>
                            <ComboBox x:Name="ComputerDescFilterBox" Width="90" SelectedIndex="0" Margin="0,0,10,0"
                                      Height="26" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="指定なし"/>
                                <ComboBoxItem Content="あり"/>
                                <ComboBoxItem Content="なし"/>
                            </ComboBox>
                            <CheckBox x:Name="IncludeDisabledComputersBox" Content="無効も表示"
                                      VerticalAlignment="Center" Margin="0,0,12,0" FontSize="12"/>
                            <Button Content="検索" Width="80" Margin="0,0,8,0"
                                    Click="ComputerSearch_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                            <Button Content="CSV出力" Width="80"
                                    Click="ExportComputerSearchResults_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </WrapPanel>
                    </Border>

                    <!-- Computer search result DataGrid -->
                    <DataGrid x:Name="ComputerSearchResultGrid" Grid.Row="1"
                              AutoGenerateColumns="False" SelectionMode="Single"
                              IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionChanged="ComputerSearchResultGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="コンピュータ名"  Binding="{Binding Name}"            Width="2*"/>
                            <DataGridTextColumn Header="DNSHostName"   Binding="{Binding DnsHostName}"     Width="2*"/>
                            <DataGridTextColumn Header="OS"            Binding="{Binding OperatingSystem}" Width="3*"/>
                            <DataGridCheckBoxColumn Header="有効"      Binding="{Binding Enabled}"         Width="60"/>
                            <DataGridTextColumn Header="description"   Binding="{Binding Description}"    Width="3*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Description edit card -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,8,0,4">
                        <StackPanel>
                            <Border Style="{StaticResource CardHeaderBorderStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="description 編集（限定更新）"
                                               Style="{StaticResource SectionHeadingStyle}"/>
                                    <Border Style="{StaticResource BadgeWarningStyle}" Margin="10,0,0,0">
                                        <TextBlock Text="更新対象: description のみ　Domain Admins セッション必須"
                                                   FontSize="10" Foreground="{StaticResource WarningBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Grid Margin="10,8,10,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="説明 (description)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="EditComputerDescriptionBox" Grid.Column="1" Height="26"
                                         IsEnabled="{Binding ComputerEditControlsEnabled}"
                                         TextChanged="ComputerDescriptionInput_TextChanged"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Buttons and reason -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button x:Name="ComputerPreviewButton" Content="差分確認" Width="100"
                                    Margin="0,0,8,0" Click="ComputerPreview_Click"
                                    IsEnabled="{Binding ComputerEditControlsEnabled}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button x:Name="ComputerExecuteButton" Content="限定更新実行" Width="130"
                                    Margin="0,0,8,0" Click="ComputerExecute_Click"
                                    IsEnabled="{Binding IsComputerWriteButtonEnabled}"
                                    Style="{StaticResource DangerButtonStyle}"/>
                            <Button x:Name="CopyComputerRevertMemoButton" Content="戻し用メモをコピー"
                                    Width="150" Click="CopyComputerRevertMemo_Click" IsEnabled="False"
                                    Style="{StaticResource GhostButtonStyle}"
                                    ToolTip="更新成功後に変更前の値をクリップボードにコピーします"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ComputerWriteButtonDisabledReason}"
                                   Style="{StaticResource ErrorTextStyle}" Margin="0,0,0,2"/>
                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                   Text="※ 更新対象: description のみ。無効化・OU移動・削除・グループ変更は実行しません。空文字更新は禁止。実行前に再認証と確認が必要です。"/>
                    </StackPanel>

                    <!-- Detail + groups -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="230"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <Border Style="{StaticResource CardHeaderBorderStyle}">
                                    <TextBlock Text="コンピュータ詳細（参照専用）"
                                               Style="{StaticResource SectionHeadingStyle}"/>
                                </Border>
                                <TextBox x:Name="ComputerDetailBox" Margin="8"
                                         IsReadOnly="True" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                         Height="160" BorderThickness="0" Padding="0"/>
                            </StackPanel>
                        </Border>
                        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                      Background="{StaticResource BorderBrush}"/>
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                            <StackPanel>
                                <Border Style="{StaticResource CardHeaderBorderStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="所属グループ"
                                                   Style="{StaticResource SectionHeadingStyle}"/>
                                        <Button Content="コピー" Margin="10,0,0,0"
                                                Click="CopyComputerGroups_Click"
                                                Style="{StaticResource GhostButtonStyle}"/>
                                    </StackPanel>
                                </Border>
                                <TextBox x:Name="ComputerGroupListBox" Margin="8"
                                         IsReadOnly="True" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" Height="160"
                                         BorderThickness="0" Padding="0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ==================== Tab: オペレーション支援 ==================== -->
            <TabItem x:Name="OperationSupportTab" Header="オペレーション支援">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="110"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <Border Grid.Row="0" Background="{StaticResource ActionBarBgBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="ユーザー所属変更支援" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBox x:Name="OpSearchBox" Width="250" Height="26" Margin="0,0,8,0"/>
                            <Button Content="検索" Width="80"
                                    Click="OpSearch_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                            <Border Style="{StaticResource BadgeWarningStyle}" Margin="14,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="変更予定作成のみ。AD更新はユーザー編集・グループ編集タブから実行してください。"
                                           FontSize="11" Foreground="{StaticResource WarningBrush}"/>
                            </Border>
                        </WrapPanel>
                    </Border>

                    <!-- Search results -->
                    <DataGrid x:Name="OpSearchResultGrid" Grid.Row="1"
                              AutoGenerateColumns="False" SelectionMode="Single"
                              IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionChanged="OpSearchResultGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SamAccountName" Binding="{Binding SamAccountName}" Width="2*"/>
                            <DataGridTextColumn Header="DisplayName"    Binding="{Binding DisplayName}"    Width="2*"/>
                            <DataGridTextColumn Header="Mail"           Binding="{Binding Mail}"           Width="3*"/>
                            <DataGridCheckBoxColumn Header="有効"       Binding="{Binding Enabled}"        Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Current info | Change plan -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                                      Background="{StaticResource BorderBrush}"/>

                        <!-- Left: current info -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,6,0">
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Border Style="{StaticResource CardHeaderBorderStyle}">
                                            <TextBlock Text="対象ユーザー（現在の情報）"
                                                       Style="{StaticResource SectionHeadingStyle}"/>
                                        </Border>
                                        <Grid Margin="10,6,10,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="ユーザー名" Style="{StaticResource FieldLabelStyle}" FontSize="11"/>
                                            <TextBox x:Name="OpCurrentSamBox" Grid.Column="1" Height="24" IsReadOnly="True" FontSize="11"/>
                                            <TextBlock Text="表示名" Grid.Row="1" Style="{StaticResource FieldLabelStyle}" FontSize="11" Margin="0,4,0,0"/>
                                            <TextBox x:Name="OpCurrentDisplayNameBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,4,0,0" IsReadOnly="True" FontSize="11"/>
                                            <TextBlock Text="メール" Grid.Row="2" Style="{StaticResource FieldLabelStyle}" FontSize="11" Margin="0,4,0,0"/>
                                            <TextBox x:Name="OpCurrentMailBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,4,0,0" IsReadOnly="True" FontSize="11"/>
                                            <TextBlock Text="姓" Grid.Row="3" Style="{StaticResource FieldLabelStyle}" FontSize="11" Margin="0,4,0,0"/>
                                            <TextBox x:Name="OpCurrentSurnameBox" Grid.Row="3" Grid.Column="1" Height="24" Margin="0,4,0,0" IsReadOnly="True" FontSize="11"/>
                                            <TextBlock Text="名" Grid.Row="4" Style="{StaticResource FieldLabelStyle}" FontSize="11" Margin="0,4,0,0"/>
                                            <TextBox x:Name="OpCurrentGivenNameBox" Grid.Row="4" Grid.Column="1" Height="24" Margin="0,4,0,0" IsReadOnly="True" FontSize="11"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Border Style="{StaticResource CardHeaderBorderStyle}">
                                            <TextBlock Text="所属グループ（現在）"
                                                       Style="{StaticResource SectionHeadingStyle}"/>
                                        </Border>
                                        <TextBox x:Name="OpCurrentGroupsBox" Height="160" Margin="8"
                                                 IsReadOnly="True" AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto" FontSize="11"
                                                 BorderThickness="0" Padding="0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Right: change plan -->
                        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="6,0,0,0">
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Border Style="{StaticResource CardHeaderBorderStyle}">
                                            <TextBlock Text="変更予定入力（属性）"
                                                       Style="{StaticResource SectionHeadingStyle}"/>
                                        </Border>
                                        <Grid Margin="10,6,10,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="表示名" Style="{StaticResource FieldLabelStyle}" FontSize="11"/>
                                            <TextBox x:Name="OpNewDisplayNameBox" Grid.Column="1" Height="24" FontSize="11"/>
                                            <TextBlock Text="姓" Grid.Row="1" Style="{StaticResource FieldLabelStyle}" FontSize="11" Margin="0,4,0,0"/>
                                            <TextBox x:Name="OpNewSurnameBox" Grid.Row="1" Grid.Column="1" Height="24" Margin="0,4,0,0" FontSize="11"/>
                                            <TextBlock Text="名" Grid.Row="2" Style="{StaticResource FieldLabelStyle}" FontSize="11" Margin="0,4,0,0"/>
                                            <TextBox x:Name="OpNewGivenNameBox" Grid.Row="2" Grid.Column="1" Height="24" Margin="0,4,0,0" FontSize="11"/>
                                            <TextBlock Text="メール" Grid.Row="3" Style="{StaticResource FieldLabelStyle}" FontSize="11" Margin="0,4,0,0"/>
                                            <TextBox x:Name="OpNewMailBox" Grid.Row="3" Grid.Column="1" Height="24" Margin="0,4,0,0" FontSize="11"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Border Style="{StaticResource CardHeaderBorderStyle}">
                                            <TextBlock Text="グループ変更予定"
                                                       Style="{StaticResource SectionHeadingStyle}"/>
                                        </Border>
                                        <StackPanel Margin="8,6,8,8">
                                            <TextBlock Text="追加予定" FontWeight="Bold" FontSize="11"
                                                       Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,3"/>
                                            <WrapPanel Margin="0,0,0,3">
                                                <TextBox x:Name="OpGroupAddInputBox" Width="200" Height="24"
                                                         FontSize="11" Margin="0,0,6,0"
                                                         ToolTip="追加予定グループ名を入力"/>
                                                <Button Content="追加予定へ" FontSize="11" Height="24" Padding="8,0"
                                                        Click="OpAddToGroupAdds_Click"
                                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                            </WrapPanel>
                                            <Border BorderBrush="{StaticResource SuccessBrush}"
                                                    BorderThickness="1" Margin="0,0,0,2">
                                                <ListBox x:Name="OpGroupAddList" Height="56"
                                                         FontSize="11" BorderThickness="0"/>
                                            </Border>
                                            <Button Content="選択を追加予定から削除" HorizontalAlignment="Left"
                                                    FontSize="11" Height="24" Padding="8,0" Margin="0,0,0,10"
                                                    Click="OpRemoveFromGroupAdds_Click"
                                                    Style="{StaticResource GhostButtonStyle}"/>

                                            <TextBlock Text="削除予定" FontWeight="Bold" FontSize="11"
                                                       Foreground="{StaticResource DangerBrush}" Margin="0,0,0,3"/>
                                            <WrapPanel Margin="0,0,0,3">
                                                <TextBox x:Name="OpGroupRemoveInputBox" Width="200" Height="24"
                                                         FontSize="11" Margin="0,0,6,0"
                                                         ToolTip="削除予定グループ名を入力"/>
                                                <Button Content="削除予定へ" FontSize="11" Height="24" Padding="8,0"
                                                        Click="OpAddToGroupRemoves_Click"
                                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                            </WrapPanel>
                                            <Border BorderBrush="{StaticResource DangerBrush}"
                                                    BorderThickness="1" Margin="0,0,0,2">
                                                <ListBox x:Name="OpGroupRemoveList" Height="56"
                                                         FontSize="11" BorderThickness="0"/>
                                            </Border>
                                            <Button Content="選択を削除予定から削除" HorizontalAlignment="Left"
                                                    FontSize="11" Height="24" Padding="8,0"
                                                    Click="OpRemoveFromGroupRemoves_Click"
                                                    Style="{StaticResource GhostButtonStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Border Style="{StaticResource CardHeaderBorderStyle}">
                                            <TextBlock Text="確認チェックリスト"
                                                       Style="{StaticResource SectionHeadingStyle}"/>
                                        </Border>
                                        <StackPanel Margin="8,6,8,8">
                                            <CheckBox x:Name="OpCheck1" Content="対象ユーザーに誤りがない" FontSize="12" Margin="0,2,0,2"/>
                                            <CheckBox x:Name="OpCheck2" Content="変更後の属性（表示名・姓・名）に誤りがない" FontSize="12" Margin="0,2,0,2"/>
                                            <CheckBox x:Name="OpCheck3" Content="メールアドレスに誤りがない" FontSize="12" Margin="0,2,0,2"/>
                                            <CheckBox x:Name="OpCheck4" Content="追加グループに誤りがない" FontSize="12" Margin="0,2,0,2"/>
                                            <CheckBox x:Name="OpCheck5" Content="削除グループに誤りがない" FontSize="12" Margin="0,2,0,2"/>
                                            <CheckBox x:Name="OpCheck6" Content="関係部署の確認が済んでいる" FontSize="12" Margin="0,2,0,2"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <WrapPanel Margin="0,0,0,6">
                                    <Button Content="変更予定サマリー生成" Width="160" Margin="0,0,8,0"
                                            Click="OpGenerateSummary_Click"
                                            Style="{StaticResource PrimaryButtonStyle}"/>
                                    <Button Content="クリップボードにコピー" Width="160"
                                            Click="OpCopySummary_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"/>
                                </WrapPanel>
                                <TextBox x:Name="OpSummaryBox" Height="180"
                                         IsReadOnly="True" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="11"
                                         Background="{StaticResource OutputBgBrush}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ==================== Tab: GPOシミュレーション ==================== -->
            <TabItem Header="GPOシミュレーション（簡易）">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Input area -->
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource CardHeaderBorderStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="シミュレーション設定"
                                               Style="{StaticResource SectionHeadingStyle}"/>
                                    <Border Style="{StaticResource BadgeWarningStyle}" Margin="10,0,0,0">
                                        <TextBlock Text="OUリンクから推定する簡易シミュレーション。GPO編集・リンク変更は実行しません。"
                                                   FontSize="10" Foreground="{StaticResource WarningBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <StackPanel Margin="10,8,10,8">
                                <WrapPanel Margin="0,0,0,8" VerticalAlignment="Center">
                                    <TextBlock Text="種別" VerticalAlignment="Center"
                                               Style="{StaticResource FieldLabelStyle}" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="GpoKindComboBox" Width="230" Height="26"
                                              SelectedIndex="0" VerticalContentAlignment="Center"
                                              SelectionChanged="GpoKindComboBox_SelectionChanged">
                                        <ComboBoxItem Content="ユーザー"/>
                                        <ComboBoxItem Content="コンピュータ"/>
                                        <ComboBoxItem Content="ユーザー + コンピュータ"/>
                                    </ComboBox>
                                </WrapPanel>
                                <WrapPanel x:Name="GpoUserInputPanel" Margin="0,0,0,6" Visibility="Visible">
                                    <TextBlock Text="sAMAccountName" VerticalAlignment="Center"
                                               Style="{StaticResource FieldLabelStyle}" Width="130"/>
                                    <TextBox x:Name="GpoUserSamBox" Width="280" Height="26"/>
                                </WrapPanel>
                                <WrapPanel x:Name="GpoComputerInputPanel" Margin="0,0,0,6" Visibility="Collapsed">
                                    <TextBlock Text="コンピュータ名" VerticalAlignment="Center"
                                               Style="{StaticResource FieldLabelStyle}" Width="130"/>
                                    <TextBox x:Name="GpoComputerNameBox" Width="280" Height="26"/>
                                </WrapPanel>
                                <Button Content="シミュレーション実行" Width="160"
                                        HorizontalAlignment="Left" Margin="0,4,0,0"
                                        Click="GpoSimulate_Click"
                                        Style="{StaticResource PrimaryButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Result DataGrid -->
                    <DataGrid x:Name="GpoResultGrid" Grid.Row="1"
                              AutoGenerateColumns="False" SelectionMode="Single"
                              Margin="0,0,0,8" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="GPO名"      Binding="{Binding GpoName}"     Width="3*"/>
                            <DataGridTextColumn Header="GPO ID"     Binding="{Binding GpoId}"       Width="3*"/>
                            <DataGridTextColumn Header="適用対象"   Binding="{Binding AppliesTo}"   Width="*"/>
                            <DataGridTextColumn Header="リンク先OU" Binding="{Binding LinkedOuDn}"  Width="4*"/>
                            <DataGridCheckBoxColumn Header="有効"   Binding="{Binding LinkEnabled}" Width="50"/>
                            <DataGridCheckBoxColumn Header="強制"   Binding="{Binding Enforced}"    Width="50"/>
                            <DataGridTextColumn Header="備考"       Binding="{Binding Remarks}"     Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Action buttons -->
                    <WrapPanel Grid.Row="2">
                        <Button Content="結果をコピー" Width="120" Margin="0,0,8,0"
                                Click="GpoCopyResults_Click"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                        <Button Content="簡易コピー" Width="100" Margin="0,0,8,0"
                                Click="GpoCopySimpleResults_Click"
                                Style="{StaticResource GhostButtonStyle}"
                                ToolTip="CSV出力と同じ列・順序のテキストをコピーします"/>
                        <Button Content="CSV出力" Width="100"
                                Click="GpoExportCsv_Click"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <!-- ==================== Tab: 未ログイン確認 ==================== -->
            <TabItem Header="未ログイン確認">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource ActionBarBgBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                        <WrapPanel>
                            <TextBlock Text="対象" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                            <ComboBox x:Name="InactiveTargetComboBox" Width="120" Height="26"
                                      SelectedIndex="0" Margin="0,0,14,0"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="ユーザー"/>
                                <ComboBoxItem Content="コンピュータ"/>
                            </ComboBox>
                            <TextBlock Text="未ログイン日数" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                            <TextBox x:Name="InactiveDaysBox" Width="80" Height="26" Text="90" Margin="0,0,4,0"/>
                            <TextBlock Text="日以上" VerticalAlignment="Center"
                                       Style="{StaticResource MutedTextStyle}" Margin="0,0,14,0"/>
                            <Button Content="検索" Width="80" Margin="0,0,8,0"
                                    Click="InactiveSearch_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                            <Button Content="CSV出力" Width="90"
                                    Click="InactiveExportCsv_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                            <TextBlock Text="※ lastLogonTimestamp が未設定の対象も含みます。"
                                       Style="{StaticResource MutedTextStyle}"
                                       VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </WrapPanel>
                    </Border>

                    <TextBlock x:Name="InactiveStatusText" Grid.Row="1" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>

                    <Grid Grid.Row="2">
                        <DataGrid x:Name="InactiveUserGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SamAccountName"    Binding="{Binding SamAccountName}"                                     Width="2*"/>
                                <DataGridTextColumn Header="DisplayName"        Binding="{Binding DisplayName}"                                        Width="2*"/>
                                <DataGridTextColumn Header="Mail"               Binding="{Binding Mail}"                                               Width="3*"/>
                                <DataGridTextColumn Header="最終ログオン"       Binding="{Binding LastLogonAt, StringFormat=yyyy-MM-dd HH:mm:ss}"      Width="2*"/>
                                <DataGridCheckBoxColumn Header="有効"           Binding="{Binding Enabled}"                                            Width="50"/>
                                <DataGridTextColumn Header="DistinguishedName" Binding="{Binding DistinguishedName}"                                  Width="4*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <DataGrid x:Name="InactiveComputerGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Single" Visibility="Collapsed">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="コンピュータ名"    Binding="{Binding Name}"                                               Width="2*"/>
                                <DataGridTextColumn Header="DNSHostName"       Binding="{Binding DnsHostName}"                                        Width="2*"/>
                                <DataGridTextColumn Header="OS"                Binding="{Binding OperatingSystem}"                                    Width="3*"/>
                                <DataGridTextColumn Header="最終ログオン"      Binding="{Binding LastLogonAt, StringFormat=yyyy-MM-dd HH:mm:ss}"      Width="2*"/>
                                <DataGridCheckBoxColumn Header="有効"          Binding="{Binding Enabled}"                                            Width="50"/>
                                <DataGridTextColumn Header="DistinguishedName" Binding="{Binding DistinguishedName}"                                  Width="4*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ==================== Tab: ログ確認 ==================== -->
            <TabItem Header="ログ確認">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Log kind + load -->
                    <Border Grid.Row="0" Style="{StaticResource BadgeWarningStyle}"
                            Margin="0,0,0,6" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WarningTextStyle}"
                                       Text="⚠ ログにはAD属性・DN・操作履歴など内部情報が含まれます。CSV出力した内容の管理に注意してください。ログの編集・削除は行いません（閲覧専用）。"/>
                            <WrapPanel Margin="0,6,0,0">
                                <TextBlock Text="ログ種別" VerticalAlignment="Center"
                                           Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                <ComboBox x:Name="LogKindComboBox" Width="180" Height="26"
                                          SelectedIndex="0" Margin="0,0,14,0"
                                          VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="参照ログ (audit.jsonl)"/>
                                    <ComboBoxItem Content="認証ログ (auth.jsonl)"/>
                                    <ComboBoxItem Content="書き込みログ (write-audit.jsonl)"/>
                                </ComboBox>
                                <Button Content="読み込み" Width="90" Margin="0,0,8,0"
                                        Click="LogLoad_Click"
                                        Style="{StaticResource PrimaryButtonStyle}"/>
                                <Button Content="フォルダを開く" Width="110"
                                        Click="LogOpenFolder_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                <TextBlock x:Name="LogWarningText" Foreground="{StaticResource WarningBrush}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Margin="14,0,0,0" TextWrapping="Wrap"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Filters -->
                    <Border Grid.Row="1" Background="{StaticResource ActionBarBgBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                        <WrapPanel>
                            <TextBlock Text="開始日" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,4,0"/>
                            <DatePicker x:Name="LogStartDatePicker" Width="120" Margin="0,0,12,0"/>
                            <TextBlock Text="終了日" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,4,0"/>
                            <DatePicker x:Name="LogEndDatePicker" Width="120" Margin="0,0,12,0"/>
                            <TextBlock Text="成否" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,4,0"/>
                            <ComboBox x:Name="LogSuccessFilterComboBox" Width="80" Height="26"
                                      SelectedIndex="0" Margin="0,0,12,0"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="すべて"/>
                                <ComboBoxItem Content="成功"/>
                                <ComboBoxItem Content="失敗"/>
                            </ComboBox>
                            <TextBlock Text="操作キーワード" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,4,0"/>
                            <TextBox x:Name="LogActionFilterBox" Width="140" Height="26" Margin="0,0,12,0"/>
                            <TextBlock Text="対象キーワード" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}" Margin="0,0,4,0"/>
                            <TextBox x:Name="LogTargetFilterBox" Width="140" Height="26" Margin="0,0,12,0"/>
                            <Button Content="フィルター適用" Width="110" Margin="0,0,6,0"
                                    Click="LogFilter_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                            <Button Content="クリア" Width="70"
                                    Click="LogFilterClear_Click"
                                    Style="{StaticResource GhostButtonStyle}"/>
                        </WrapPanel>
                    </Border>

                    <!-- Status -->
                    <TextBlock x:Name="LogStatusText" Grid.Row="2" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>

                    <!-- Log DataGrid -->
                    <DataGrid x:Name="LogGrid" Grid.Row="3"
                              AutoGenerateColumns="False" SelectionMode="Single" IsReadOnly="True"
                              SelectionChanged="LogGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="日時"          Binding="{Binding TimestampDisplay}" Width="150"/>
                            <DataGridTextColumn Header="操作"          Binding="{Binding Action}"           Width="2*"/>
                            <DataGridTextColumn Header="対象"          Binding="{Binding Target}"           Width="2*"/>
                            <DataGridTextColumn Header="実行者・編集者" Binding="{Binding ExecutorDisplay}"  Width="2*"/>
                            <DataGridTextColumn Header="成否"          Binding="{Binding SuccessDisplay}"   Width="60"/>
                            <DataGridTextColumn Header="備考"          Binding="{Binding DetailSummary}"    Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Splitter -->
                    <GridSplitter Grid.Row="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource BorderBrush}"/>

                    <!-- Detail JSON pane -->
                    <Grid Grid.Row="5" Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="詳細（JSON）" Style="{StaticResource SectionHeadingStyle}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button Content="コピー" Width="70"
                                    Click="LogCopyDetail_Click"
                                    Style="{StaticResource GhostButtonStyle}"/>
                        </StackPanel>
                        <TextBox x:Name="LogDetailBox" Grid.Row="1"
                                 FontFamily="Consolas" FontSize="12"
                                 IsReadOnly="True" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"/>
                    </Grid>

                    <!-- CSV export -->
                    <WrapPanel Grid.Row="6" Margin="0,6,0,0">
                        <Button Content="CSV出力" Width="100"
                                Click="LogExportCsv_Click"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                        <TextBlock Text="※ ログファイルは直接編集しないでください。参照のみ。"
                                   Style="{StaticResource MutedTextStyle}"
                                   VerticalAlignment="Center" Margin="14,0,0,0"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Row 3: Output section -->
        <Border Grid.Row="3" Background="{StaticResource AppBgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="結果をコピー" VerticalAlignment="Top" Margin="0,0,10,0"
                        Click="CopyOutput_Click"
                        Style="{StaticResource GhostButtonStyle}"/>
                <TextBox x:Name="OutputBox" Grid.Column="1" Height="96"
                         AcceptsReturn="True" IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         Background="{StaticResource OutputBgBrush}" FontSize="12"
                         BorderBrush="{StaticResource BorderBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
