<Window x:Class="ManageAdTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ManageAdTool" Height="980" Width="1200">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Search bar -->
        <WrapPanel Margin="0,0,0,8" VerticalAlignment="Center">
            <TextBlock Text="検索語" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox x:Name="SearchBox" Width="220" Margin="0,0,8,0"/>
            <TextBlock Text="部署" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox x:Name="DepartmentFilterBox" Width="160" Margin="0,0,8,0"/>
            <TextBlock Text="Mail" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="MailFilterBox" Width="120" SelectedIndex="0" Margin="0,0,8,0">
                <ComboBoxItem Content="指定なし"/>
                <ComboBoxItem Content="あり"/>
                <ComboBoxItem Content="なし"/>
            </ComboBox>
            <CheckBox x:Name="IncludeDisabledUsersBox" Content="無効ユーザーも表示" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button Content="検索" Width="100" Margin="0,0,8,0" Click="Search_Click"/>
            <Button Content="検索結果CSV出力" Width="140" Click="ExportSearchResults_Click"/>
        </WrapPanel>

        <!-- Row 1: Search result DataGrid -->
        <DataGrid x:Name="SearchResultGrid" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="SearchResultGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="SamAccountName" Binding="{Binding SamAccountName}" Width="2*"/>
                <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="2*"/>
                <DataGridTextColumn Header="Mail" Binding="{Binding Mail}" Width="3*"/>
                <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="2*"/>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*"/>
                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 2: Edit blocked reason -->
        <TextBlock x:Name="EditBlockedReasonText" Grid.Row="2" Foreground="DarkRed" FontWeight="Bold" Margin="0,8,0,4" Text="{Binding EditBlockedReason}"/>

        <!-- Row 3: Editor login (Domain Admins) -->
        <GroupBox Grid.Row="3" Header="編集者ログイン（Domain Admins 判定）" Margin="0,0,0,8">
            <WrapPanel Margin="4">
                <TextBlock Text="ユーザー (domain\user)" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="EditorUserBox" Width="200" Margin="0,0,8,0" IsEnabled="{Binding CanLoginInput}"/>
                <TextBlock Text="パスワード" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <PasswordBox x:Name="EditorPasswordBox" Width="160" Margin="0,0,8,0" IsEnabled="{Binding CanLoginInput}"/>
                <Button Content="ログイン" Width="80" Margin="0,0,8,0" Click="Login_Click" IsEnabled="{Binding CanLoginInput}"/>
                <Button Content="ログアウト" Width="90" Margin="0,0,8,0" Click="Logout_Click" IsEnabled="{Binding IsEditSessionActive}"/>
                <TextBlock Text="{Binding SessionStatusText}" VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{Binding SessionStatusBrush}" TextWrapping="Wrap"/>
            </WrapPanel>
        </GroupBox>

        <!-- Row 4: Attribute edit GroupBox -->
        <GroupBox Grid.Row="4" Margin="0,0,0,8">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="属性表示・変更予定確認 / 限定更新"/>
                    <TextBlock Text="【更新対象: メールアドレス / 表示名 / 姓 / 名】【ユーザー名は参照のみ（v0.4.2 更新対象外）】【Domain Admins セッション必須】"
                               Foreground="DarkOrange" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </GroupBox.Header>
            <Grid Margin="8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="メールアドレス (mail)" VerticalAlignment="Center"/>
                <TextBox x:Name="EditMailBox" Grid.Column="1" IsEnabled="{Binding EditControlsEnabled}" TextChanged="EditInput_TextChanged"/>
                <TextBlock Text="表示名 (displayName)" Grid.Row="1" VerticalAlignment="Center" Margin="0,4,0,0"/>
                <TextBox x:Name="EditDisplayNameBox" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0" IsEnabled="{Binding EditControlsEnabled}" TextChanged="EditInput_TextChanged"/>
                <TextBlock Text="姓 (sn)" Grid.Row="2" VerticalAlignment="Center" Margin="0,4,0,0"/>
                <TextBox x:Name="EditSurnameBox" Grid.Row="2" Grid.Column="1" Margin="0,4,0,0" IsEnabled="{Binding EditControlsEnabled}" TextChanged="EditInput_TextChanged"/>
                <TextBlock Text="名 (givenName)" Grid.Row="3" VerticalAlignment="Center" Margin="0,4,0,0"/>
                <TextBox x:Name="EditGivenNameBox" Grid.Row="3" Grid.Column="1" Margin="0,4,0,0" IsEnabled="{Binding EditControlsEnabled}" TextChanged="EditInput_TextChanged"/>
                <TextBlock Text="ユーザー名 ※参照のみ（高リスク）" Grid.Row="4" VerticalAlignment="Center" Margin="0,4,0,0" Foreground="Gray"/>
                <TextBox x:Name="SamAccountNameReadBox" Grid.Row="4" Grid.Column="1" Margin="0,4,0,0"
                         IsReadOnly="True" Background="#F4F4F4" Foreground="DimGray"
                         ToolTip="ユーザー名（sAMAccountName）は参照のみです。v0.4.2では更新できません。"/>
            </Grid>
        </GroupBox>

        <!-- Row 5: Tab control -->
        <TabControl Grid.Row="5" Margin="0,0,0,8">
            <TabItem Header="ユーザー詳細">
                <StackPanel Margin="8">
                    <TextBlock Text="ユーザー詳細（表示のみ）" FontWeight="Bold"/>
                    <TextBox x:Name="UserDetailBox" Height="120" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,4,0,8" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="所属グループ（表示のみ・名前順）" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="グループをコピー" Width="120" Margin="12,0,0,0" Click="CopyGroups_Click"/>
                    </StackPanel>
                    <TextBox x:Name="GroupListBox" Height="90" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>
                    <StackPanel Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button x:Name="PreviewButton" Content="差分確認" Width="100" Margin="0,0,8,0" Click="Preview_Click" IsEnabled="{Binding EditControlsEnabled}"/>
                            <Button x:Name="ExecuteButton" Content="限定更新実行" Width="130" Click="Execute_Click"
                                    IsEnabled="{Binding IsWriteButtonEnabled}"
                                    Background="#CC3333" Foreground="White" FontWeight="Bold" Margin="0,0,8,0"/>
                            <Button x:Name="CopyRevertMemoButton" Content="戻し用メモをコピー" Width="150"
                                    Click="CopyRevertMemo_Click" IsEnabled="False" Margin="0,0,0,0"
                                    ToolTip="更新成功後に変更前の値をクリップボードにコピーします"/>
                        </StackPanel>
                        <TextBlock Text="{Binding WriteButtonDisabledReason}"
                                   Foreground="DarkRed" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,2"/>
                        <TextBlock Text="※ 更新対象: メールアドレス / 表示名 / 姓 / 名（LDAPattr: mail / displayName / sn / givenName）。ユーザー名は参照のみ。空文字更新は禁止。実行前に再認証と確認が必要です。"
                                   Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="グループ参照・メンバー編集">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Group search bar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="グループ検索" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="GroupSearchBox" Width="260" Margin="0,0,8,0"/>
                        <Button Content="検索" Width="100" Click="GroupSearch_Click"/>
                    </StackPanel>

                    <!-- Row 1: Group search result grid -->
                    <DataGrid x:Name="GroupSearchResultGrid" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="GroupSearchResultGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="DistinguishedName" Binding="{Binding DistinguishedName}" Width="5*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Row 2: Detail + edit split panel -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: member detail -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="90"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="60"/>
                            </Grid.RowDefinitions>
                            <TextBox x:Name="GroupDetailBox" Grid.Row="0" IsReadOnly="True" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,4">
                                <TextBlock Text="ユーザーメンバー" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="選択を削除予定へ" Width="120" Margin="8,0,0,0"
                                        Click="GroupAddToRemoveStaging_Click"
                                        IsEnabled="{Binding GroupEditControlsEnabled}"
                                        ToolTip="選択中のユーザーを削除予定リストに追加します"/>
                            </StackPanel>
                            <DataGrid x:Name="GroupUserMemberGrid" Grid.Row="2" AutoGenerateColumns="False" SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="SamAccountName" Binding="{Binding SamAccountName}" Width="2*"/>
                                    <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="2*"/>
                                    <DataGridTextColumn Header="Mail" Binding="{Binding Mail}" Width="3*"/>
                                    <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="2*"/>
                                    <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBox x:Name="GroupOtherMembersBox" Grid.Row="3" IsReadOnly="True" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" Margin="0,4,0,0" FontSize="11"
                                     ToolTip="コンピュータメンバー、ネストグループ、所属グループ（memberOf）"/>
                        </Grid>

                        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                        <!-- Right: edit panel -->
                        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="4,0,0,0">
                            <StackPanel>
                                <GroupBox Margin="0,0,0,8">
                                    <GroupBox.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="メンバー編集"/>
                                            <TextBlock Text="【ユーザーのみ・Domain Admins必須】"
                                                       Foreground="DarkOrange" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </GroupBox.Header>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{Binding GroupEditBlockedReason}" Foreground="DarkRed" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,0,0,6"/>
                                        <TextBlock Text="追加するユーザーのSamAccountName:" FontSize="11" Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBox x:Name="GroupAddUserBox" Width="140" Margin="0,0,4,0"
                                                     IsEnabled="{Binding GroupEditControlsEnabled}"/>
                                            <Button Content="検索して追加予定へ" FontSize="11"
                                                    Click="GroupAddUserToStaging_Click"
                                                    IsEnabled="{Binding GroupEditControlsEnabled}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="追加予定:" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                            <Button Content="選択を除去" FontSize="10" Margin="6,0,0,0" Width="60"
                                                    Click="GroupRemoveFromAddStaging_Click"/>
                                        </StackPanel>
                                        <ListBox x:Name="GroupAddStagingList" Height="70" FontSize="11" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="削除予定:" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                            <Button Content="選択を除去" FontSize="10" Margin="6,0,0,0" Width="60"
                                                    Click="GroupRemoveFromRemoveStaging_Click"/>
                                        </StackPanel>
                                        <ListBox x:Name="GroupRemoveStagingList" Height="70" FontSize="11" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Button x:Name="GroupPreviewButton" Content="差分確認" Width="90" Margin="0,0,8,0"
                                                    Click="GroupPreview_Click"
                                                    IsEnabled="{Binding GroupEditControlsEnabled}"/>
                                            <Button x:Name="GroupExecuteButton" Content="限定更新実行" Width="120"
                                                    Click="GroupExecute_Click"
                                                    IsEnabled="{Binding IsGroupWriteButtonEnabled}"
                                                    Background="#CC3333" Foreground="White" FontWeight="Bold"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding GroupWriteButtonDisabledReason}"
                                                   Foreground="DarkRed" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                        <TextBlock Foreground="Gray" FontSize="10" TextWrapping="Wrap"
                                                   Text="※ ユーザーのみ追加・削除可能。コンピュータ・グループの追加は不可。グループ作成・削除・リネームは実行しません。"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="コンピュータ参照">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="150"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Computer search bar -->
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="検索語" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="ComputerSearchBox" Width="180" Margin="0,0,8,0"/>
                        <TextBlock Text="OS" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="ComputerOsFilterBox" Width="130" Margin="0,0,8,0"/>
                        <TextBlock Text="description" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="ComputerDescFilterBox" Width="90" SelectedIndex="0" Margin="0,0,8,0">
                            <ComboBoxItem Content="指定なし"/>
                            <ComboBoxItem Content="あり"/>
                            <ComboBoxItem Content="なし"/>
                        </ComboBox>
                        <CheckBox x:Name="IncludeDisabledComputersBox" Content="無効も表示" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="検索" Width="100" Margin="0,0,8,0" Click="ComputerSearch_Click"/>
                        <Button Content="CSV出力" Width="90" Click="ExportComputerSearchResults_Click"/>
                    </WrapPanel>

                    <!-- Row 1: Computer search result DataGrid -->
                    <DataGrid x:Name="ComputerSearchResultGrid" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="ComputerSearchResultGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="DNSHostName" Binding="{Binding DnsHostName}" Width="2*"/>
                            <DataGridTextColumn Header="OperatingSystem" Binding="{Binding OperatingSystem}" Width="3*"/>
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="Auto"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="3*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Row 2: Edit description GroupBox -->
                    <GroupBox Grid.Row="2" Margin="0,8,0,4">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="description 編集"/>
                                <TextBlock Text="【更新対象: description のみ・Domain Admins セッション必須】"
                                           Foreground="DarkOrange" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="説明 (description)" VerticalAlignment="Center"/>
                            <TextBox x:Name="EditComputerDescriptionBox" Grid.Column="1"
                                     IsEnabled="{Binding ComputerEditControlsEnabled}"
                                     TextChanged="ComputerDescriptionInput_TextChanged"/>
                        </Grid>
                    </GroupBox>

                    <!-- Row 3: Buttons and reason -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button x:Name="ComputerPreviewButton" Content="差分確認" Width="100" Margin="0,0,8,0"
                                    Click="ComputerPreview_Click" IsEnabled="{Binding ComputerEditControlsEnabled}"/>
                            <Button x:Name="ComputerExecuteButton" Content="限定更新実行" Width="130"
                                    Click="ComputerExecute_Click"
                                    IsEnabled="{Binding IsComputerWriteButtonEnabled}"
                                    Background="#CC3333" Foreground="White" FontWeight="Bold" Margin="0,0,8,0"/>
                            <Button x:Name="CopyComputerRevertMemoButton" Content="戻し用メモをコピー" Width="150"
                                    Click="CopyComputerRevertMemo_Click" IsEnabled="False"
                                    ToolTip="更新成功後に変更前の値をクリップボードにコピーします"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ComputerWriteButtonDisabledReason}"
                                   Foreground="DarkRed" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,2"/>
                        <TextBlock Text="※ 更新対象: description のみ。無効化・OU移動・削除・グループ変更は実行しません。空文字更新は禁止。実行前に再認証と確認が必要です。"
                                   Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Row 4: Detail + groups -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ComputerDetailBox" IsReadOnly="True" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="4,0,0,4">
                                <TextBlock Text="所属グループ" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="コピー" Width="55" Margin="8,0,0,0" Click="CopyComputerGroups_Click"/>
                            </StackPanel>
                            <TextBox x:Name="ComputerGroupListBox" IsReadOnly="True" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" Height="200" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- オペレーション支援タブ -->
            <TabItem Header="オペレーション支援">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="110"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <WrapPanel Margin="0,0,0,6" VerticalAlignment="Center">
                        <TextBlock Text="ユーザー所属変更支援" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox x:Name="OpSearchBox" Width="240" Margin="0,0,6,0"/>
                        <Button Content="検索" Width="80" Click="OpSearch_Click"/>
                        <TextBlock Text="※ 変更予定作成のみ。AD更新はユーザー編集・グループ編集タブから実行してください。"
                                   VerticalAlignment="Center" Foreground="DarkOrange" FontSize="11" Margin="12,0,0,0"/>
                    </WrapPanel>

                    <!-- Search results -->
                    <DataGrid x:Name="OpSearchResultGrid" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single"
                              SelectionChanged="OpSearchResultGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SamAccountName" Binding="{Binding SamAccountName}" Width="2*"/>
                            <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="2*"/>
                            <DataGridTextColumn Header="Mail" Binding="{Binding Mail}" Width="3*"/>
                            <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="2*"/>
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Main area: left (current info) | splitter | right (change plan) -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="330"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

                        <!-- Left: current info -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,6,0">
                                <GroupBox Header="対象ユーザー（現在の情報）" Margin="0,0,0,6">
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="ユーザー名" VerticalAlignment="Center" FontSize="11"/>
                                        <TextBox x:Name="OpCurrentSamBox" Grid.Column="1" IsReadOnly="True" Background="#F4F4F4" Foreground="DimGray" FontSize="11"/>
                                        <TextBlock Text="表示名" Grid.Row="1" VerticalAlignment="Center" Margin="0,3,0,0" FontSize="11"/>
                                        <TextBox x:Name="OpCurrentDisplayNameBox" Grid.Row="1" Grid.Column="1" Margin="0,3,0,0" IsReadOnly="True" Background="#F4F4F4" Foreground="DimGray" FontSize="11"/>
                                        <TextBlock Text="メール" Grid.Row="2" VerticalAlignment="Center" Margin="0,3,0,0" FontSize="11"/>
                                        <TextBox x:Name="OpCurrentMailBox" Grid.Row="2" Grid.Column="1" Margin="0,3,0,0" IsReadOnly="True" Background="#F4F4F4" Foreground="DimGray" FontSize="11"/>
                                        <TextBlock Text="姓" Grid.Row="3" VerticalAlignment="Center" Margin="0,3,0,0" FontSize="11"/>
                                        <TextBox x:Name="OpCurrentSurnameBox" Grid.Row="3" Grid.Column="1" Margin="0,3,0,0" IsReadOnly="True" Background="#F4F4F4" Foreground="DimGray" FontSize="11"/>
                                        <TextBlock Text="名" Grid.Row="4" VerticalAlignment="Center" Margin="0,3,0,0" FontSize="11"/>
                                        <TextBox x:Name="OpCurrentGivenNameBox" Grid.Row="4" Grid.Column="1" Margin="0,3,0,0" IsReadOnly="True" Background="#F4F4F4" Foreground="DimGray" FontSize="11"/>
                                    </Grid>
                                </GroupBox>
                                <GroupBox Header="所属グループ（現在）">
                                    <TextBox x:Name="OpCurrentGroupsBox" Height="170" IsReadOnly="True" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto" FontSize="11" Background="#F4F4F4" Foreground="DimGray"/>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Right: change plan -->
                        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="6,0,0,0">
                                <GroupBox Header="変更予定入力（属性）" Margin="0,0,0,6">
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="表示名" VerticalAlignment="Center" FontSize="11"/>
                                        <TextBox x:Name="OpNewDisplayNameBox" Grid.Column="1" FontSize="11"/>
                                        <TextBlock Text="姓" Grid.Row="1" VerticalAlignment="Center" Margin="0,3,0,0" FontSize="11"/>
                                        <TextBox x:Name="OpNewSurnameBox" Grid.Row="1" Grid.Column="1" Margin="0,3,0,0" FontSize="11"/>
                                        <TextBlock Text="名" Grid.Row="2" VerticalAlignment="Center" Margin="0,3,0,0" FontSize="11"/>
                                        <TextBox x:Name="OpNewGivenNameBox" Grid.Row="2" Grid.Column="1" Margin="0,3,0,0" FontSize="11"/>
                                        <TextBlock Text="メールアドレス" Grid.Row="3" VerticalAlignment="Center" Margin="0,3,0,0" FontSize="11"/>
                                        <TextBox x:Name="OpNewMailBox" Grid.Row="3" Grid.Column="1" Margin="0,3,0,0" FontSize="11"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="グループ変更予定" Margin="0,0,0,6">
                                    <StackPanel Margin="4">
                                        <TextBlock Text="追加予定" FontWeight="Bold" FontSize="11" Foreground="DarkGreen" Margin="0,0,0,2"/>
                                        <WrapPanel Margin="0,0,0,2">
                                            <TextBox x:Name="OpGroupAddInputBox" Width="200" FontSize="11" Margin="0,0,4,0" ToolTip="追加予定グループ名を入力"/>
                                            <Button Content="追加予定へ" FontSize="11" Padding="6,2" Click="OpAddToGroupAdds_Click"/>
                                        </WrapPanel>
                                        <Border BorderBrush="DarkGreen" BorderThickness="1" Margin="0,0,0,2">
                                            <ListBox x:Name="OpGroupAddList" Height="60" FontSize="11" BorderThickness="0"/>
                                        </Border>
                                        <Button Content="選択を追加予定から削除" HorizontalAlignment="Left" FontSize="11" Padding="6,2" Margin="0,0,0,8" Click="OpRemoveFromGroupAdds_Click"/>

                                        <TextBlock Text="削除予定" FontWeight="Bold" FontSize="11" Foreground="DarkRed" Margin="0,0,0,2"/>
                                        <WrapPanel Margin="0,0,0,2">
                                            <TextBox x:Name="OpGroupRemoveInputBox" Width="200" FontSize="11" Margin="0,0,4,0" ToolTip="削除予定グループ名を入力"/>
                                            <Button Content="削除予定へ" FontSize="11" Padding="6,2" Click="OpAddToGroupRemoves_Click"/>
                                        </WrapPanel>
                                        <Border BorderBrush="DarkRed" BorderThickness="1" Margin="0,0,0,2">
                                            <ListBox x:Name="OpGroupRemoveList" Height="60" FontSize="11" BorderThickness="0"/>
                                        </Border>
                                        <Button Content="選択を削除予定から削除" HorizontalAlignment="Left" FontSize="11" Padding="6,2" Click="OpRemoveFromGroupRemoves_Click"/>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="確認チェックリスト" Margin="0,0,0,6">
                                    <StackPanel Margin="4">
                                        <CheckBox x:Name="OpCheck1" Content="対象ユーザーに誤りがない" FontSize="11" Margin="0,2,0,2"/>
                                        <CheckBox x:Name="OpCheck2" Content="変更後の属性（表示名・姓・名）に誤りがない" FontSize="11" Margin="0,2,0,2"/>
                                        <CheckBox x:Name="OpCheck3" Content="メールアドレスに誤りがない" FontSize="11" Margin="0,2,0,2"/>
                                        <CheckBox x:Name="OpCheck4" Content="追加グループに誤りがない" FontSize="11" Margin="0,2,0,2"/>
                                        <CheckBox x:Name="OpCheck5" Content="削除グループに誤りがない" FontSize="11" Margin="0,2,0,2"/>
                                        <CheckBox x:Name="OpCheck6" Content="関係部署の確認が済んでいる" FontSize="11" Margin="0,2,0,2"/>
                                    </StackPanel>
                                </GroupBox>

                                <WrapPanel Margin="0,0,0,4">
                                    <Button Content="変更予定サマリー生成" Width="160" Margin="0,0,8,0" Click="OpGenerateSummary_Click"/>
                                    <Button Content="クリップボードにコピー" Width="160" Click="OpCopySummary_Click"/>
                                </WrapPanel>
                                <TextBox x:Name="OpSummaryBox" Height="200" IsReadOnly="True" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11" Background="#F9F9F9"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>
            <!-- GPOシミュレーションタブ -->
            <TabItem Header="GPOシミュレーション">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Input area -->
                    <GroupBox Header="シミュレーション設定" Margin="0,0,0,8">
                        <StackPanel Margin="4">
                            <WrapPanel Margin="0,0,0,6" VerticalAlignment="Center">
                                <TextBlock Text="種別" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="GpoKindComboBox" Width="220" SelectedIndex="0"
                                          SelectionChanged="GpoKindComboBox_SelectionChanged">
                                    <ComboBoxItem Content="ユーザー"/>
                                    <ComboBoxItem Content="コンピュータ"/>
                                    <ComboBoxItem Content="ユーザー + コンピュータ"/>
                                </ComboBox>
                                <TextBlock Text="※ GPO 参照・シミュレーションのみ。GPO 編集・リンク変更は実行しません。"
                                           VerticalAlignment="Center" Foreground="DarkOrange" FontSize="11" Margin="12,0,0,0"/>
                            </WrapPanel>

                            <WrapPanel x:Name="GpoUserInputPanel" Margin="0,0,0,4" Visibility="Visible">
                                <TextBlock Text="sAMAccountName" VerticalAlignment="Center" Width="130"/>
                                <TextBox x:Name="GpoUserSamBox" Width="260"/>
                            </WrapPanel>

                            <WrapPanel x:Name="GpoComputerInputPanel" Margin="0,0,0,4" Visibility="Collapsed">
                                <TextBlock Text="コンピュータ名" VerticalAlignment="Center" Width="130"/>
                                <TextBox x:Name="GpoComputerNameBox" Width="260"/>
                            </WrapPanel>

                            <Button Content="シミュレーション実行" Width="160" HorizontalAlignment="Left"
                                    Margin="0,4,0,0" Click="GpoSimulate_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Result DataGrid -->
                    <DataGrid x:Name="GpoResultGrid" Grid.Row="1" AutoGenerateColumns="False"
                              SelectionMode="Single" Margin="0,0,0,8" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="GPO名" Binding="{Binding GpoName}" Width="3*"/>
                            <DataGridTextColumn Header="GPO ID" Binding="{Binding GpoId}" Width="3*"/>
                            <DataGridTextColumn Header="適用対象" Binding="{Binding AppliesTo}" Width="*"/>
                            <DataGridTextColumn Header="リンク先OU" Binding="{Binding LinkedOuDn}" Width="4*"/>
                            <DataGridCheckBoxColumn Header="有効" Binding="{Binding LinkEnabled}" Width="Auto"/>
                            <DataGridCheckBoxColumn Header="強制適用" Binding="{Binding Enforced}" Width="Auto"/>
                            <DataGridTextColumn Header="備考" Binding="{Binding Remarks}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Action buttons -->
                    <WrapPanel Grid.Row="2">
                        <Button Content="結果をコピー" Width="120" Margin="0,0,8,0" Click="GpoCopyResults_Click"/>
                        <Button Content="CSV出力" Width="100" Click="GpoExportCsv_Click"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Row 6: Output GroupBox -->
        <GroupBox Grid.Row="6" Header="処理結果欄">
            <StackPanel>
                <Button Content="結果をコピー" Width="100" HorizontalAlignment="Left" Margin="0,0,0,4" Click="CopyOutput_Click"/>
                <TextBox x:Name="OutputBox" Height="130" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
